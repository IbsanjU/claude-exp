# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Session Secret
SESSION_SECRET=your-secret-key-change-this-in-production

# Guacamole Configuration (if using separate Guacamole server)
GUACAMOLE_HOST=localhost
GUACAMOLE_PORT=4822

# ─── Streaming Configuration ─────────────────────────────────────────────────

# Provider: "mock" (local dev, no AWS needed) or "ivs" (real Amazon IVS)
STREAMING_PROVIDER=mock

# AWS credentials (only needed when STREAMING_PROVIDER=ivs)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# IVS recording: create an S3 bucket and a RecordingConfiguration in IVS console
IVS_RECORDING_BUCKET=your-recordings-bucket
IVS_RECORDING_CONFIG_ARN=arn:aws:ivs:us-east-1:123456789012:recording-configuration/xxxxxxxxxxxx

# ECS Fargate for FFmpeg relay (stream pre-recorded video as live)
# Create a Fargate task def with the ffmpeg Docker image (see infra/ecs/)
ECS_CLUSTER=streaming-poc
FFMPEG_TASK_DEFINITION=ffmpeg-relay
ECS_SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
ECS_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
